# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=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

# Murf AI API Key (Required for text-to-speech)
