{
    "name": "auralis-ai-root",
    "version": "1.0.0",
    "description": "Root package for Auralis AI managing frontend and backend scripts",
    "private": true,
    "scripts": {
        "install:frontend": "cd frontend && npm install",
        "dev:frontend": "cd frontend && npm run dev",
        "build:frontend": "cd frontend && npm run build",
        "start:frontend": "cd frontend && npm run start",
        "install:backend": "cd backend && pip install -r requirements.txt",
        "dev:backend": "cd backend && uvicorn src.main:app --reload --host 0.0.0.0 --port 8000",
        "dev": "echo 'Run dev:frontend and dev:backend in separate terminals'"
    },
    "keywords": [],
    "author": "",
    "license": "ISC"
}